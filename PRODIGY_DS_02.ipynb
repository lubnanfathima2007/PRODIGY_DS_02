# PRODIGY INFOTECH - DATA SCIENCE INTERNSHIP
# Task 02: Data Cleaning & Exploratory Data Analysis (EDA)
# Dataset: Titanic (Kaggle)
# ============================================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings

warnings.filterwarnings('ignore')
sns.set_theme(style="whitegrid", palette="muted")

# ─────────────────────────────────────────
# 1. DOWNLOAD & LOAD THE DATA
# ─────────────────────────────────────────
import urllib.request
import pandas as pd

url = "https://raw.githubusercontent.com/datasciencedojo/datasets/master/titanic.csv"
urllib.request.urlretrieve(url, "train.csv")

df = pd.read_csv("train.csv")
print("Shape:", df.shape)
print(df.head())

# ─────────────────────────────────────────
# 2. INITIAL EXPLORATION
# ─────────────────────────────────────────
print("\nData Types & Non-Null Counts:")
print(df.info())

print("\nBasic Statistics:")
print(df.describe())

print("\nMissing Values:")
print(df.isnull().sum())

# ─────────────────────────────────────────
# 3. DATA CLEANING
# ─────────────────────────────────────────

# Fill missing Age with median
df['Age'].fillna(df['Age'].median(), inplace=True)

# Fill missing Embarked with mode
df['Embarked'].fillna(df['Embarked'].mode()[0], inplace=True)

# Drop Cabin (too many missing values) and irrelevant columns
df.drop(columns=['Cabin', 'Ticket', 'Name', 'PassengerId'], inplace=True)

# Check for duplicates
print(f"\nDuplicate rows: {df.duplicated().sum()}")
df.drop_duplicates(inplace=True)

# Encode Sex as numeric for correlation
df['Sex_encoded'] = df['Sex'].map({'male': 0, 'female': 1})

print("\nCleaned Data Shape:", df.shape)
print("Missing values after cleaning:\n", df.isnull().sum())

# ─────────────────────────────────────────
# 4. UNIVARIATE ANALYSIS
# ─────────────────────────────────────────
fig, axes = plt.subplots(1, 3, figsize=(16, 4))
fig.suptitle("Univariate Analysis", fontsize=14, fontweight='bold')

# Age distribution
axes[0].hist(df['Age'], bins=30, color='steelblue', edgecolor='white')
axes[0].set_title("Age Distribution")
axes[0].set_xlabel("Age")

# Passenger class
df['Pclass'].value_counts().sort_index().plot(kind='bar', ax=axes[1],
                                               color=['#4e79a7','#f28e2b','#e15759'],
                                               edgecolor='white')
axes[1].set_title("Passenger Class Distribution")
axes[1].set_xlabel("Class")
axes[1].tick_params(rotation=0)

# Survival rate pie chart
df['Survived'].value_counts().plot(kind='pie', ax=axes[2],
                                    labels=['Did Not Survive', 'Survived'],
                                    autopct='%1.1f%%',
                                    colors=['#e15759','#76b7b2'],
                                    startangle=90)
axes[2].set_ylabel("")
axes[2].set_title("Survival Rate")

plt.tight_layout()
plt.savefig("univariate_analysis.png", dpi=150)
plt.show()

# ─────────────────────────────────────────
# 5. BIVARIATE ANALYSIS
# ─────────────────────────────────────────
fig, axes = plt.subplots(1, 3, figsize=(16, 5))
fig.suptitle("Bivariate Analysis", fontsize=14, fontweight='bold')

# Survival by Gender
sns.countplot(data=df, x='Sex', hue='Survived', ax=axes[0],
              palette={0: '#e15759', 1: '#76b7b2'})
axes[0].set_title("Survival by Gender")
axes[0].legend(["Did Not Survive", "Survived"])

# Survival by Passenger Class
sns.countplot(data=df, x='Pclass', hue='Survived', ax=axes[1],
              palette={0: '#e15759', 1: '#76b7b2'})
axes[1].set_title("Survival by Class")
axes[1].legend(["Did Not Survive", "Survived"])

# Age vs Fare scatter
axes[2].scatter(df[df['Survived']==0]['Age'], df[df['Survived']==0]['Fare'],
                alpha=0.4, label='Did Not Survive', color='#e15759', s=20)
axes[2].scatter(df[df['Survived']==1]['Age'], df[df['Survived']==1]['Fare'],
                alpha=0.4, label='Survived', color='#76b7b2', s=20)
axes[2].set_xlabel("Age")
axes[2].set_ylabel("Fare")
axes[2].set_title("Age vs Fare")
axes[2].legend()

plt.tight_layout()
plt.savefig("bivariate_analysis.png", dpi=150)
plt.show()

# ─────────────────────────────────────────
# 6. MULTIVARIATE ANALYSIS
# ─────────────────────────────────────────

# Heatmap — Correlation Matrix
plt.figure(figsize=(9, 6))
corr = df[['Survived', 'Pclass', 'Age', 'SibSp', 'Parch', 'Fare', 'Sex_encoded']].corr()
sns.heatmap(corr, annot=True, fmt=".2f", cmap="coolwarm", square=True,
            linewidths=0.5)
plt.title("Correlation Heatmap", fontsize=13, fontweight='bold')
plt.tight_layout()
plt.savefig("correlation_heatmap.png", dpi=150)
plt.show()

# Fare distribution by Class (Box Plot)
plt.figure(figsize=(8, 5))
sns.boxplot(data=df, x='Pclass', y='Fare', palette='Set2')
plt.title("Fare Distribution by Passenger Class", fontweight='bold')
plt.tight_layout()
plt.savefig("fare_by_class.png", dpi=150)
plt.show()

# Survival rate by Embarked
plt.figure(figsize=(6, 4))
sns.barplot(data=df, x='Embarked', y='Survived', palette='Set1',
            order=['S', 'C', 'Q'])
plt.title("Survival Rate by Port of Embarkation", fontweight='bold')
plt.ylabel("Survival Rate")
plt.tight_layout()
plt.savefig("survival_by_embarked.png", dpi=150)
plt.show()

# ─────────────────────────────────────────
# 7. KEY INSIGHTS SUMMARY
# ─────────────────────────────────────────
print("\n" + "="*50)
print("KEY INSIGHTS")
print("="*50)

survival_by_sex = df.groupby('Sex')['Survived'].mean()
print(f"\nSurvival Rate by Gender:\n{survival_by_sex.to_string()}")

survival_by_class = df.groupby('Pclass')['Survived'].mean()
print(f"\nSurvival Rate by Class:\n{survival_by_class.to_string()}")

print(f"\nOverall Survival Rate: {df['Survived'].mean():.2%}")
print(f"Median Age: {df['Age'].median():.1f} years")
print(f"Average Fare: ₹{df['Fare'].mean():.2f}")
print("="*50)
